{
  "name": "devbridge",
  "version": "1.0.0",
  "type": "module",
  "description": "Control your projects via Telegram using Claude CLI, Gemini CLI, or any AI coding agent",
  "main": "dist/index.js",
  "bin": {
    "devbridge": "./dist/bin/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "yarn build && yarn test"
  },
  "keywords": [
    "telegram",
    "bot",
    "claude",
    "gemini",
    "ai",
    "cli",
    "developer-tools",
    "devbridge",
    "coding-agent"
  ],
  "author": "vinicius1209",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinicius1209/devbridge.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "grammy": "^1.31.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
